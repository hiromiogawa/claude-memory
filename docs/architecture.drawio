  <diagram name="Search Pipeline" id="search-pipe">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="sp-title" value="Search Pipeline — memory_search" style="text;html=1;fontSize=20;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="sp-query" value="&lt;b&gt;検索クエリ&lt;/b&gt;&lt;br&gt;&amp;quot;TypeScriptの型エラー&amp;quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="250" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="sp-embed" value="&lt;b&gt;[1] Embedding&lt;/b&gt;&lt;br&gt;ONNX → 384次元ベクトル" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="220" width="250" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="sp-keyword" value="&lt;b&gt;[2] Keyword Search&lt;/b&gt;&lt;br&gt;pg_bigm (LIKE + bigm_similarity)&lt;br&gt;→ スコア付きランキング" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="340" width="250" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="sp-vector" value="&lt;b&gt;[3] Vector Search&lt;/b&gt;&lt;br&gt;pgvector (cosine distance)&lt;br&gt;→ 類似度スコア" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="440" width="250" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="sp-parallel" value="並列実行" style="text;html=1;fontSize=11;fontStyle=2;fontColor=#82b366;align=center;rotation=-90;" vertex="1" parent="1">
          <mxGeometry x="10" y="385" width="80" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="sp-rrf" value="&lt;b&gt;[4] RRF&lt;/b&gt;&lt;br&gt;Reciprocal Rank Fusion&lt;br&gt;k = 60" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="370" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="sp-decay" value="&lt;b&gt;[5] Time Decay&lt;/b&gt;&lt;br&gt;score × 0.5^(days / 30)&lt;br&gt;半減期 30日" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="800" y="370" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="sp-result" value="&lt;b&gt;検索結果&lt;/b&gt;&lt;br&gt;スコア順 Top N&lt;br&gt;matchType: keyword | vector | hybrid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1100" y="370" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="sp-e1" value="" style="rounded=1;strokeWidth=2;" edge="1" source="sp-query" target="sp-embed" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sp-e2" value="" style="rounded=1;strokeWidth=2;" edge="1" source="sp-embed" target="sp-keyword" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sp-e3" value="" style="rounded=1;strokeWidth=2;" edge="1" source="sp-embed" target="sp-vector" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sp-e4" value="" style="rounded=1;strokeWidth=2;" edge="1" source="sp-keyword" target="sp-rrf" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sp-e5" value="" style="rounded=1;strokeWidth=2;" edge="1" source="sp-vector" target="sp-rrf" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sp-e6" value="" style="rounded=1;strokeWidth=2;" edge="1" source="sp-rrf" target="sp-decay" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sp-e7" value="" style="rounded=1;strokeWidth=2;" edge="1" source="sp-decay" target="sp-result" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
