{
  "name": "claude-memory",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:unit": "pnpm --filter @claude-memory/core run test",
    "lint": "oxlint -c .oxlintrc.json packages/*/src && biome check packages/*/src",
    "format": "biome check --write .",
    "knip": "knip",
    "dep-check": "depcruise --config .dependency-cruiser.cjs packages/",
    "docs:dep-graph": "depcruise --config .dependency-cruiser.cjs --output-type dot packages/ | dot -Tsvg > docs/generated/dependency-graph.svg",
    "docs:schema": "tbls doc --force",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "onnxruntime-node"
    ],
    "packageExtensions": {
      "@huggingface/transformers@3.4.1": {
        "dependencies": {
          "onnxruntime-common": "1.20.1"
        }
      }
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "oxlint -c .oxlintrc.json"
    ],
    "*.{ts,tsx,js,json}": [
      "biome check --write"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "dependency-cruiser": "17.3.10",
    "husky": "9.1.7",
    "knip": "6.0.1",
    "lint-staged": "16.4.0",
    "oxlint": "1.56.0"
  }
}
