{
  "plugins": ["jsdoc"],
  "rules": {
    "all": "warn",
    "no-magic-numbers": [
      "warn",
      {
        "ignore": [0, 1, -1, 2],
        "ignoreEnums": true,
        "ignoreReadonlyClassProperties": true
      }
    ]
  },
  "ignorePatterns": ["dist/", "node_modules/", "coverage/", "**/*.test.ts"]
}
