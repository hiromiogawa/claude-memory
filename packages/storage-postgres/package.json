  "dependencies": {
    "@claude-memory/core": "workspace:*",
    "drizzle-orm": "0.39.3",
    "drizzle-zod": "0.7.1",
    "postgres": "3.4.5"
  },
  "devDependencies": {
    "typescript": "5.7.3",
    "vitest": "3.1.1",
    "@vitest/coverage-v8": "3.1.1",
    "drizzle-kit": "0.30.5",
    "@types/node": "22.15.3"
  }
}
